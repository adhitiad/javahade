# ======================
# Kreativa Platform — Environment Variables
# ======================
# Copy this to .env and fill in your values

# --- General ---
PROJECT_NAME=kreativa
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
DATABASE_URL=postgres://kreativa:kreativa_pass@localhost:5432/kreativa_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=kreativa_chat

# --- JWT ---
JWT_SECRET_KEY=change-me-shared-jwt-secret-between-python-and-go
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- S3 / MinIO ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=kreativa-media
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Email (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@kreativa.app

# --- OvenMediaEngine ---
OME_API_URL=http://localhost:8081/v1
OME_API_ACCESS_TOKEN=your-ome-api-token

# --- Go Service Ports ---
BOOKING_SERVICE_PORT=8080
CHAT_SERVICE_PORT=8081
STREAM_SERVICE_PORT=8082

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Payment (prepared for future) ---
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# MIDTRANS_SERVER_KEY=xxx
# XENDIT_SECRET_KEY=xxx
