# Payment Service Environment Variables

# Server
PORT=3000
NODE_ENV=development

# Database (Supabase PostgreSQL via Pooler)
# Format: postgres://[user]:[password]@[host]:[port]/[db]
DATABASE_URL=postgres://postgres:postgres@localhost:6543/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Gateway Secrets
VEROTEL_SHOP_ID=your_verotel_shop_id
VEROTEL_SIGNATURE=your_verotel_signature_key

SEGPAY_PACKAGE_ID=your_segpay_package_id

NETBILLING_ACCOUNT_ID=your_netbilling_account_id

ELOTPAY_API_KEY=your_elotpay_api_key

# Payout
PAXUM_EMAIL=your_paxum_account_email
PAXUM_SECRET=your_paxum_api_secret

# Wise Integration (if applicable later)
WISE_USD_ACCOUNT=your_wise_usd_account
